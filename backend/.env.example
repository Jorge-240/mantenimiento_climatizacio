# ==================== CONFIGURACIÓN BACKEND ====================
# Copiar este archivo a .env y actualizar valores

# ==================== BASE DE DATOS ====================
# Desarrollo Local (Docker)
DATABASE_URL="mysql://sena:senapass123@localhost:3306/mantenimiento_climatizacion"

# Producción Railway/Clever Cloud
# DATABASE_URL="mysql://user:pass@containers-us-west-XXX.railway.app:NNNN/mantenimiento_climatizacion"

# ==================== AUTENTICACIÓN ====================
JWT_SECRET="tu-super-secreto-jwt-key-muy-larga-para-produccion-cambiar-en-produccion-123456789"

# ==================== SERVIDOR ====================
PORT=3001
NODE_ENV=development

# ==================== CLOUDINARY (Opcional - para subida de imágenes) ====================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==================== CORS ====================
# URLs permitidas del frontend
FRONTEND_URL=http://localhost:5173
MOBILE_URLS=exp://192.168.1.0:19000

